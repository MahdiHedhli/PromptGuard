# Copy to .env and fill in. .env is gitignored.

# Upstream LLM keys. The Day-1 stack does not enforce policy; if you set
# these, traffic forwards unmediated. Day 2 adds the pre-call hook.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LiteLLM master key used by the proxy itself for auth between local tools
# and the proxy. Default ships as a clearly-fake dev value; rotate before
# any non-loopback exposure.
LITELLM_MASTER_KEY=sk-promptguard-dev

# Host-side port overrides. Internal container ports are fixed; only the
# host-side bind is configurable. Use these when something on your host
# is already listening on the default port.
# PROMPTGUARD_LITELLM_PORT=4000
# PROMPTGUARD_PRESIDIO_PORT=5002
# PROMPTGUARD_OPF_PORT=8081

# Policy source. Default reads YAML from PROMPTGUARD_POLICY_FILE.
# Valid: local_yaml | purview_dlp | icap | git_manifest. See docs/adapters.md.
# PROMPTGUARD_POLICY_SOURCE=local_yaml
# PROMPTGUARD_POLICY_FILE=/app/policies/default.yaml

# Hot-reload polling interval (seconds). 0 disables. See DEC-016.
# PROMPTGUARD_POLICY_RELOAD_INTERVAL_S=0

# OPF service runtime config.
# OPF_MODEL_ID=openai/privacy-filter
# OPF_DEVICE=cpu
