# =============================================================================
# Local-only working folder for runtime artifacts, scratch work, benchmark
# outputs that are NOT shipped with the project. Subtree organization:
#   local/audit/            runtime audit log files
#   local/benchmarks/results/  benchmark CSV / JSON outputs
#   local/scratch/          ad-hoc experiments
# =============================================================================
local/
*-audit.log
audit.log
promptguard-audit.log

